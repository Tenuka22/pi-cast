{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types", "node"],
    "paths": {
      "@/*": ["src/*"],
    },
  },
  "include": ["src/**/*.ts", "env.d.ts", "worker-configuration.d.ts", "*.config.ts", ],
  "exclude": ["node_modules", "dist", ".wrangler"],
}
