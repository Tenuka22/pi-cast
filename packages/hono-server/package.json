{
  "name": "@pi-cast/hono-server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./middleware": "./src/middleware.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "wrangler dev --var \"__VARLOCK_ENV:$(varlock load --format json-full)\"",
    "deploy": "wrangler deploy --var \"__VARLOCK_ENV:$(varlock load --format json-full)\"",
    "build": "varlock run -- tsc",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test:rate-limit": "bun run tests/rate-limit.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@orpc/server": "^1.7.0",
    "@pi-cast/db": "workspace:*",
    "@pi-cast/orpc-handlers": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.0",
    "varlock": "^0.6.2",
    "wrangler": "^4.76.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
