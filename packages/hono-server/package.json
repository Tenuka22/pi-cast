{
  "name": "@pi-cast/hono-server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "varlock run -- tsx watch src/index.ts",
    "start": "varlock run -- tsx src/index.ts",
    "build": "varlock run -- tsc",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "varlock run -- tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@orpc/server": "^1.7.0",
    "@pi-cast/db": "workspace:*",
    "@pi-cast/orpc-handlers": "workspace:*",
    "drizzle-orm": "^1.0.0-beta.18-7eb39f0",
    "hono": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
