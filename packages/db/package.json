{
  "name": "@pi-cast/db",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "auth:generate": "varlock run -- bun x auth@latest generate --y --config='../orpc-handlers/src/auth/auth-config.ts' --output='./src/auth.schema.ts'",
    "db:migrate": "varlock run -- bunx drizzle-kit migrate",
    "db:generate": "varlock run -- bunx drizzle-kit generate",
    "db:push": "varlock run -- bunx drizzle-kit push",
    "db:studio": "varlock run -- bunx drizzle-kit studio"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
